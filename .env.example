# Firebase Authentication Configuration for Alankaran Custom Image CMS
# Replace these values with your Firebase Project credentials from Console -> Project Settings -> General
VITE_FIREBASE_API_KEY="your-api-key-here"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# Cloudinary Storage Configuration (Phase 2)
# Replace with your Cloudinary account details from Dashboard -> Settings -> Upload
VITE_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
VITE_CLOUDINARY_UPLOAD_PRESET="alankaran_cms_preset"
VITE_CLOUDINARY_FOLDER="alankaran_website"
VITE_CLOUDINARY_API_BASE_URL="https://api.cloudinary.com/v1_1"
